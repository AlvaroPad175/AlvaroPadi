# Configuración de variables de entorno para el Sistema de Seguridad de ONG

# ===== CRÍTICO: CONTRASEÑA MAESTRA =====
# Esta es la contraseña maestra del sistema. Se usa para derivar todas las claves de encriptación.
# IMPORTANTE: Cambia esto a una contraseña fuerte y única. Mantenla segura.
# En producción en Hostgator, almacena esto en:
#   1. Variables de entorno del servidor (recomendado)
#   2. Secret Manager de Hostgator (si disponible)
#   3. Nunca en .git o repositorio público
CRYPTO_MASTER_PASSWORD=TuContraseña@SuperFuerte2024!

# ===== RUTAS DE BASE DE DATOS =====
# Ruta donde se almacena la BD de usuarios y metadatos criptográficos
DATABASE_PATH=./data/usuarios_ong.db

# Ruta donde se guarda el archivo de datos encriptados
DATA_ENCRYPTED_PATH=./data/base_encriptada.xlsx

# ===== NIVEL DE LOG =====
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== CONFIGURACIÓN DE CONTRASEÑAS (Recomendado: No cambiar) =====
# Mínimo caracteres
MIN_PASSWORD_LENGTH=12

# Requerir mayúsculas
REQUIRE_UPPERCASE=True

# Requerir minúsculas
REQUIRE_LOWERCASE=True

# Requerir números
REQUIRE_DIGITS=True

# Requerir caracteres especiales
REQUIRE_SPECIAL_CHARS=True

# ===== RATE LIMITING (Anti-fuerza bruta) =====
# Máximo de intentos fallidos antes de bloquear
MAX_LOGIN_ATTEMPTS=5

# Tiempo de bloqueo en minutos (después de MAX_LOGIN_ATTEMPTS fallos)
LOCKOUT_DURATION_MINUTES=15

# ===== CONFIGURACIÓN DE CRIPTOGRAFÍA (Avanzado: No cambiar) =====
# Número de iteraciones PBKDF2 (más es más seguro pero más lento)
# Recomendado por OWASP: 100,000 (puede ser hasta 1,000,000)
KEY_DERIVATION_ITERATIONS=100000

# Algoritmo de hash para PBKDF2 (sha256 recomendado)
PBKDF2_HASH_ALGORITHM=sha256

# Tamaño de clave en bytes (32 = 256 bits para AES-256)
KEY_SIZE=32
